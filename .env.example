NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/loden?schema=public
JWT_SECRET=local-dev-secret-change-before-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3006,http://127.0.0.1:3006
API_USE_MEMORY=false
LODEN_API_URL=http://127.0.0.1:4000

# IA (optionnel). Sans GROQ_API_KEY, l'assistant renvoie un message clair (désactivé).
# Clé gratuite : https://console.groq.com
AI_PROVIDER=groq
AI_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=

# --- Mesure d'audience (optionnel, RGPD-friendly) ---
# Matomo (traceur principal, sans cookie + IP anonymisée = exempté de consentement).
# Renseigner l'URL de l'instance Matomo (racine, avec slash final) et l'ID du site.
NEXT_PUBLIC_MATOMO_URL=
NEXT_PUBLIC_MATOMO_SITE_ID=
# GA4 optionnel : laisser vide pour ne pas le charger.
NEXT_PUBLIC_GA4_ID=
# Côté serveur : lecture de l'API Reporting Matomo pour le tableau de bord CRM
# (« Statistiques & Trafic »). Le token reste secret, jamais exposé au navigateur.
MATOMO_URL=
MATOMO_SITE_ID=
MATOMO_API_TOKEN=
