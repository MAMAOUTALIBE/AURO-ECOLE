generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  DIRECTEUR
  RESPONSABLE_AGENCE
  RESPONSABLE_PEDAGOGIQUE
  ADMIN
  SECRETAIRE
  COMPTABLE
  MONITEUR
  EDITEUR
  ELEVE
  VISITEUR
}

enum UserStatus {
  PENDING_EMAIL
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum StudentFileStatus {
  NOUVEAU
  INCOMPLET
  EN_COURS
  PRET_EXAMEN
  EXAMEN_PLANIFIE
  TERMINE
  ARCHIVE
}

enum FormationMode {
  MANUEL
  AUTOMATIQUE
  MIXTE
  CODE
}

enum ProductLine {
  AUTO_ECOLE
  VTC
  CACES
  SST
  LOGISTIQUE_SECURITE
  DIGITAL
}

enum TaxMode {
  TTC
  HT
}

enum CpfStatus {
  NON_RENSEIGNE
  NON_ELIGIBLE
  POSSIBLE
  A_CONFIRMER
  ELIGIBLE
}

enum BookingStatus {
  EN_ATTENTE
  CONFIRMEE
  ANNULEE
  TERMINEE
  ABSENT
}

enum PaymentStatus {
  EN_ATTENTE
  PAYE
  ECHOUE
  REMBOURSE
  PARTIEL
}

enum PaymentKind {
  FORMATION
  ACOMPTE
  ECHEANCE
  REMBOURSEMENT
}

enum CpfRequestStatus {
  NOUVELLE_DEMANDE
  EN_COURS
  DOCUMENTS_MANQUANTS
  VALIDEE
  REFUSEE
}

enum ContactRequestStatus {
  NOUVELLE
  EN_COURS
  TRAITEE
  ARCHIVEE
}

enum ContactRequestType {
  INFORMATION
  RAPPEL
  INSCRIPTION
  CPF
  AUTRE
}

enum ReviewStatus {
  EN_ATTENTE
  PUBLIE
  REJETE
}

enum LeadStatus {
  PROSPECT
  CONTACTE
  RELANCE
  DEVIS_ENVOYE
  INSCRIT
  BON_UTILISE
  PERDU
}

enum ExamType {
  CODE
  CONDUITE
}

enum ExamResult {
  EN_ATTENTE
  REUSSI
  ECHOUE
  ABSENT
}

enum InstallmentStatus {
  EN_ATTENTE
  PAYE
  EN_RETARD
}

enum InvoiceStatus {
  BROUILLON
  EMISE
  PAYEE
  ANNULEE
}

model Invoice {
  id             String        @id @default(cuid())
  number         String?       @unique
  status         InvoiceStatus @default(BROUILLON)
  clientUserId   String
  studentId      String?
  agencyId       String?
  paymentId      String?       @unique
  lines          Json
  subtotalCents  Int
  vatCents       Int
  totalCents     Int
  currency       String        @default("EUR")
  issuerSnapshot Json?
  clientSnapshot Json?
  issuedAt       DateTime?
  dueDate        DateTime?
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  client  User     @relation("InvoiceClient", fields: [clientUserId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  agency  Agency?  @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([agencyId, issuedAt])
  @@index([clientUserId])
}

model InvoiceCounter {
  year       Int @id
  lastNumber Int @default(0)
}

enum QuoteStatus {
  BROUILLON
  ENVOYE
  ACCEPTE
  REFUSE
  EXPIRE
}

model Quote {
  id             String      @id @default(cuid())
  number         String?     @unique
  status         QuoteStatus @default(BROUILLON)
  clientUserId   String
  studentId      String?
  agencyId       String?
  lines          Json
  subtotalCents  Int
  vatCents       Int
  totalCents     Int
  currency       String      @default("EUR")
  issuerSnapshot Json?
  clientSnapshot Json?
  sentAt         DateTime?
  validUntil     DateTime?
  decidedAt      DateTime?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  client  User     @relation("QuoteClient", fields: [clientUserId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  agency  Agency?  @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  @@index([agencyId, sentAt])
  @@index([clientUserId])
}

model QuoteCounter {
  year       Int @id
  lastNumber Int @default(0)
}

enum ContractStatus {
  BROUILLON
  ACTIF
  RESILIE
  TERMINE
}

model Contract {
  id             String         @id @default(cuid())
  number         String?        @unique
  status         ContractStatus @default(BROUILLON)
  clientUserId   String
  studentId      String?
  formationId    String?
  agencyId       String?
  title          String
  body           String
  totalCents     Int            @default(0)
  currency       String         @default("EUR")
  issuerSnapshot Json?
  clientSnapshot Json?
  signedAt       DateTime?
  startsAt       DateTime?
  endsAt         DateTime?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  client  User     @relation("ContractClient", fields: [clientUserId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  agency  Agency?  @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  @@index([agencyId, signedAt])
  @@index([clientUserId])
}

model ContractCounter {
  year       Int @id
  lastNumber Int @default(0)
}

enum ContentType {
  PAGE
  ARTICLE
}

model ContentEntry {
  id             String      @id @default(cuid())
  type           ContentType
  title          String
  slug           String
  excerpt        String?
  body           String
  coverImageUrl  String?
  category       String?
  seoTitle       String?
  seoDescription String?
  published      Boolean     @default(false)
  publishedAt    DateTime?
  agencyId       String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([type, published])
  @@index([slug])
}

enum AutomationTrigger {
  LEAD_CREATED
  STUDENT_CREATED
}

enum AutomationAction {
  SEND_WELCOME_EMAIL
  NOTIFY_TEAM
  LOG
}

model AutomationRule {
  id        String            @id @default(cuid())
  name      String
  trigger   AutomationTrigger
  action    AutomationAction
  active    Boolean           @default(true)
  agencyId  String?
  runCount  Int               @default(0)
  lastRunAt DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([trigger, active])
}

model User {
  id                 String     @id @default(cuid())
  firstName          String
  lastName           String
  email              String     @unique
  phone              String?
  address            String?
  role               UserRole   @default(ELEVE)
  status             UserStatus @default(PENDING_EMAIL)
  passwordHash       String?
  preferences        Json?
  emailVerifiedAt    DateTime?
  lastLoginAt        DateTime?
  resetTokenHash     String?
  resetTokenExpiresAt DateTime?
  // Incrémenté à chaque réinitialisation de mot de passe : invalide tous les JWT
  // émis avant (révocation de session stateless).
  tokenVersion       Int        @default(0)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  student            Student?
  instructor         Instructor?
  contactRequests    ContactRequest[]
  payments           Payment[]
  reviews            Review[]
  auditLogs          AuditLog[]
  agencyMemberships  AgencyMembership[]
  invoices           Invoice[]          @relation("InvoiceClient")
  quotes             Quote[]            @relation("QuoteClient")
  contracts          Contract[]         @relation("ContractClient")
}

model Agency {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  address     String?
  latitude    Float?
  longitude   Float?
  phone       String?
  email       String?
  openingHours Json?
  brand       Json?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships     AgencyMembership[]
  students        Student[]
  instructors     Instructor[]
  vehicles        Vehicle[]
  meetingPoints   MeetingPoint[]
  availabilities  Availability[]
  bookings        Booking[]
  payments        Payment[]
  cpfRequests     CpfRequest[]
  contactRequests ContactRequest[]
  leads           Lead[]
  reviews         Review[]
  exams           Exam[]
  installments    Installment[]
  invoices        Invoice[]
  quotes          Quote[]
  contracts       Contract[]
}

model AgencyMembership {
  id        String   @id @default(cuid())
  userId    String
  agencyId  String
  role      UserRole @default(SECRETAIRE)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([userId, agencyId])
  @@index([agencyId])
}

model Student {
  id                 String            @id @default(cuid())
  userId             String            @unique
  formationId        String?
  progressPercent    Int               @default(0)
  purchasedHours     Int               @default(0)
  consumedHours      Int               @default(0)
  examDate           DateTime?
  fileStatus         StudentFileStatus @default(NOUVEAU)
  internalNotes      String?
  // État civil & gestion auto-école (style Kréno2) — structuré pour liste/filtres/fiche.
  civility           String?
  birthName          String?
  birthDate          DateTime?
  birthPlace         String?
  neph               String?
  filiere            String?
  financingType      String?
  registeredAt       DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  agencyId           String?

  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  formation          Formation?        @relation(fields: [formationId], references: [id])
  agency             Agency?           @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  documents          StudentDocument[]
  bookings           Booking[]
  cpfRequests        CpfRequest[]
  exams              Exam[]
  skills             StudentSkill[]
  installments       Installment[]
  invoices           Invoice[]
  quotes             Quote[]
  contracts          Contract[]
}

model StudentDocument {
  id          String   @id @default(cuid())
  studentId   String
  type        String
  url         String
  verifiedAt  DateTime?
  createdAt   DateTime @default(now())

  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Instructor {
  id             String   @id @default(cuid())
  userId         String   @unique
  photoUrl       String?
  bio            String?
  specialties    String[]
  interventionZones String[]
  ratingAverage  Float    @default(0)
  ratingCount    Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  agencyId       String?

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agency         Agency?  @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  vehicles       Vehicle[]
  availabilities Availability[]
  bookings       Booking[]
  reviews        Review[]
}

model Vehicle {
  id            String     @id @default(cuid())
  instructorId  String?
  label         String
  transmission  FormationMode
  registration  String?
  active        Boolean    @default(true)
  agencyId      String?

  instructor    Instructor? @relation(fields: [instructorId], references: [id], onDelete: SetNull)
  agency        Agency?     @relation(fields: [agencyId], references: [id], onDelete: SetNull)
}

model Formation {
  id                 String        @id @default(cuid())
  title              String
  slug               String        @unique
  subtitle           String?
  description        String
  mode               FormationMode
  productLine        ProductLine   @default(AUTO_ECOLE)
  priceCents         Int
  taxMode            TaxMode       @default(TTC)
  quoteOnly          Boolean       @default(false)
  // Prix interne (coût/base de calcul de devis) — JAMAIS exposé côté site public ni agent IA public.
  internalPriceCents Int?
  durationLabel      String
  defaultHours       Int?
  imageUrl           String?
  options            Json?
  tags               String[]      @default([])
  cpfEligible        Boolean       @default(false)
  cpfStatus          CpfStatus     @default(NON_RENSEIGNE)
  active             Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  students        Student[]
  pricingPlans    PricingPlan[]
  bookings        Booking[]
  cpfRequests     CpfRequest[]
}

model PricingPlan {
  id                    String   @id @default(cuid())
  formationId            String?
  title                 String
  slug                  String   @unique
  description           String?
  priceCents            Int
  features              String[]
  allowOneShotPayment   Boolean  @default(true)
  allowThreeTimes       Boolean  @default(false)
  allowFourTimes        Boolean  @default(false)
  discountCents         Int      @default(0)
  promotionalLabel      String?
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  formation             Formation? @relation(fields: [formationId], references: [id], onDelete: SetNull)
  payments              Payment[]
}

model MeetingPoint {
  id          String   @id @default(cuid())
  name        String
  address     String
  latitude    Float?
  longitude   Float?
  active      Boolean  @default(true)
  agencyId    String?
  createdAt   DateTime @default(now())

  agency      Agency?  @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  bookings    Booking[]
}

model Availability {
  id            String     @id @default(cuid())
  instructorId  String
  startsAt      DateTime
  endsAt        DateTime
  isAvailable   Boolean    @default(true)
  reason        String?
  agencyId      String?
  createdAt     DateTime   @default(now())

  instructor    Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  agency        Agency?    @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  @@index([instructorId, startsAt, endsAt])
}

model Booking {
  id              String        @id @default(cuid())
  studentId       String
  instructorId    String
  formationId     String
  meetingPointId  String?
  startsAt        DateTime
  endsAt          DateTime
  status          BookingStatus @default(EN_ATTENTE)
  cancellationReason String?
  notificationSentAt DateTime?
  agencyId        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  instructor      Instructor    @relation(fields: [instructorId], references: [id], onDelete: Restrict)
  formation       Formation     @relation(fields: [formationId], references: [id], onDelete: Restrict)
  meetingPoint    MeetingPoint? @relation(fields: [meetingPointId], references: [id], onDelete: SetNull)
  agency          Agency?       @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  @@index([instructorId, startsAt, endsAt])
  @@index([studentId, startsAt])
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  pricingPlanId   String?
  kind            PaymentKind
  status          PaymentStatus @default(EN_ATTENTE)
  amountCents     Int
  currency        String        @default("EUR")
  stripePaymentIntentId String?
  stripeCustomerId String?
  invoiceUrl      String?
  metadata        Json?
  paidAt          DateTime?
  agencyId        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  pricingPlan     PricingPlan?  @relation(fields: [pricingPlanId], references: [id], onDelete: SetNull)
  agency          Agency?       @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  invoice         Invoice?
}

model CpfRequest {
  id              String           @id @default(cuid())
  studentId       String?
  formationId     String?
  fullName        String
  email           String
  phone           String?
  status          CpfRequestStatus @default(NOUVELLE_DEMANDE)
  requestedAmountCents Int?
  missingDocuments String[]
  internalNotes    String?
  agencyId        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  student         Student?         @relation(fields: [studentId], references: [id], onDelete: SetNull)
  formation       Formation?       @relation(fields: [formationId], references: [id], onDelete: SetNull)
  agency          Agency?          @relation(fields: [agencyId], references: [id], onDelete: SetNull)
}

model ContactRequest {
  id          String               @id @default(cuid())
  userId      String?
  fullName    String
  email       String
  phone       String?
  type        ContactRequestType   @default(INFORMATION)
  source      String?
  message     String
  status      ContactRequestStatus @default(NOUVELLE)
  agencyId    String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  user        User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  agency      Agency?              @relation(fields: [agencyId], references: [id], onDelete: SetNull)
}

model Lead {
  id                  String     @id @default(cuid())
  fullName            String
  firstName           String?
  lastName            String?
  email               String
  phone               String?
  status              LeadStatus @default(PROSPECT)
  source              String?
  interest            String?
  financingType       String?
  notes               String?
  estimatedValueCents Int?
  nextFollowUpAt      DateTime?
  agencyId            String?
  temperature         String?
  score               Int?
  consentEmail        Boolean    @default(false)
  consentWhatsapp     Boolean    @default(false)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  agency              Agency?    @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([email])
}

// Rendez-vous unifié (source unique de vérité). Le nom de table reste
// "ChatAppointment" pour compatibilité, mais le modèle couvre désormais TOUS les RDV
// quelle que soit leur origine (champ `source`): chatbot, manuel, téléphone, whatsapp, crm.
// Vocabulaire canonique (colonnes String, validées par Zod côté API) :
//   source  : chatbot | manual | phone | whatsapp | crm
//   type    : call | agency | video | lesson | quote | registration
//   status  : new | pending_confirmation | confirmed | scheduled | completed | cancelled | no_show | to_follow_up
//   priority: low | normal | high | urgent
// Les FK (studentId/formationId/instructorId/vehicleId/assignedToId) sont des colonnes
// scalaires : les libellés (moniteur, conseiller, formation) sont résolus côté API/CRM
// depuis les listes existantes — pas de relations Prisma pour limiter le couplage.
model ChatAppointment {
  id                String   @id @default(cuid())
  leadId            String
  fullName          String
  firstName         String
  lastName          String
  phone             String
  email             String?
  formation         String
  objective         String
  message           String?
  notes             String?
  date              String
  time              String
  requestedAt       DateTime?
  startsAt          DateTime
  endsAt            DateTime
  type              String
  status            String   @default("pending_confirmation")
  priority          String   @default("normal")
  source            String   @default("chatbot")
  assignedToId      String?
  studentId         String?
  formationId       String?
  instructorId      String?
  vehicleId         String?
  agencyId          String?
  createdById       String?
  updatedById       String?
  consentContact    Boolean  @default(true)
  consentWhatsApp   Boolean  @default(false)
  whatsappMessage   String?
  adminEmailStatus  String   @default("pending")
  clientEmailStatus String   @default("pending")
  whatsappStatus    String   @default("pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status, createdAt])
  @@index([leadId])
  @@index([startsAt])
  @@index([source, status])
  @@index([agencyId, startsAt])
  @@index([instructorId, startsAt])
}

model ChatTask {
  id            String   @id @default(cuid())
  leadId        String
  appointmentId String?
  type          String
  priority      String   @default("HAUTE")
  assignedToId  String?
  deadline      DateTime
  note          String
  status        String   @default("A_FAIRE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, deadline])
  @@index([leadId])
  @@index([appointmentId])
}

model ChatConversation {
  id            String   @id @default(cuid())
  leadId        String?
  appointmentId String?
  visitorName   String?
  messages      Json
  summary       String?
  intent        String?
  aiConfidence  Int?
  lastMessage   String?
  status        String   @default("OUVERTE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([updatedAt])
  @@index([leadId])
  @@index([appointmentId])
}

model ChatAvailabilitySlot {
  id            String   @id @default(cuid())
  label         String
  startsAt      DateTime
  endsAt        DateTime
  type          String
  agencyId      String?
  assignedToId  String?
  active        Boolean  @default(true)
  capacity      Int      @default(1)
  bookedCount   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([active, startsAt])
}

model Review {
  id            String       @id @default(cuid())
  userId        String?
  instructorId  String?
  rating         Int
  comment        String
  authorName     String?
  authorLocation String?
  status        ReviewStatus @default(EN_ATTENTE)
  publishedAt   DateTime?
  agencyId      String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  instructor    Instructor?  @relation(fields: [instructorId], references: [id], onDelete: SetNull)
  agency        Agency?      @relation(fields: [agencyId], references: [id], onDelete: SetNull)
}

model FaqEntry {
  id          String   @id @default(cuid())
  question    String
  answer      String
  category    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Installment {
  id          String            @id @default(cuid())
  studentId   String
  agencyId    String?
  label       String?
  dueDate     DateTime
  amountCents Int
  status      InstallmentStatus @default(EN_ATTENTE)
  paidAt      DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  student     Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  agency      Agency?           @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([agencyId, dueDate])
}

model StudentSkill {
  id        String   @id @default(cuid())
  studentId String
  skillCode String
  level     Int      @default(0)
  updatedAt DateTime @updatedAt

  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, skillCode])
  @@index([studentId])
}

model Exam {
  id          String     @id @default(cuid())
  studentId   String
  agencyId    String?
  type        ExamType
  scheduledAt DateTime
  center      String?
  result      ExamResult @default(EN_ATTENTE)
  score       Int?
  attempt     Int        @default(1)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  student     Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  agency      Agency?    @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  @@index([agencyId, scheduledAt])
  @@index([studentId])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// Informations société (singleton, id = "company"), éditables depuis le CMS.
model CompanyInfo {
  id                  String   @id @default("company")
  brandName           String   @default("LODENE")
  legalName           String   @default("")
  address             String   @default("")
  postalCode          String   @default("")
  city                String   @default("")
  country             String   @default("France")
  siret               String   @default("")
  approvalNumber      String   @default("")
  phone               String   @default("")
  email               String   @default("")
  hours               String   @default("")
  legalForm           String   @default("")
  capital             String   @default("")
  publicationDirector String   @default("")
  hostingProvider     String   @default("")
  instagram           String   @default("")
  facebook            String   @default("")
  tiktok              String   @default("")
  youtube             String   @default("")
  updatedAt           DateTime @updatedAt
}

// Médiathèque : fichiers uploadés depuis le CMS (images, PDF…), réutilisables partout.
model Media {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  url          String
  mimeType     String
  sizeBytes    Int
  altText      String   @default("")
  category     String?
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdAt])
  @@index([category])
}

// Réglages dynamiques du site public, pilotés depuis le CMS (singletons clé/valeur JSON).
// Une clé par bloc éditable : "nav.primary", "nav.ctas", "hero.home", "footer",
// "sections.home", "hours", "pole.VTC"… Le site public lit ces clés (fallback data/site.ts).
model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}
