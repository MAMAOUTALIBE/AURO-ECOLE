{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "declaration": true,
    "incremental": false,
    "isolatedModules": false,
    "jsx": "react-jsx",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": "../dist/backend",
    "rootDir": "./src",
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["../node_modules", "test/**/*.test.ts"]
}
