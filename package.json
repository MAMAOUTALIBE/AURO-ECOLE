{
  "name": "loden-auto-ecole-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <25",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "api:dev": "tsx watch --env-file-if-exists=.env backend/src/main.ts",
    "api:start": "node dist/backend/main.js",
    "api:build": "tsc -p backend/tsconfig.json",
    "api:test": "vitest run --config backend/vitest.config.ts",
    "api:typecheck": "tsc -p backend/tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-availability": "tsx prisma/seed-availability.ts",
    "db:seed-demo": "tsx prisma/seed-demo.ts",
    "db:clean-demo": "tsx prisma/clean-demo.ts",
    "deploy:build": "npm run prisma:generate && npm run api:build && npm run build",
    "deploy:check": "npm run lint && npm run typecheck && npm run api:typecheck && npm run api:test && npm run api:build && npm run prisma:generate && npm run build",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^6.19.3",
    "@types/nodemailer": "^6.4.24",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.468.0",
    "multer": "^2.2.0",
    "next": "^15.1.0",
    "nodemailer": "^6.10.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.2",
    "recharts": "^2.15.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@types/supertest": "^7.2.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.15"
    }
  }
}
