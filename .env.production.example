NODE_ENV=production

# Frontend Next.js
LODEN_API_URL=http://127.0.0.1:4000

# Backend Express API
DATABASE_URL=postgresql://loden_user:CHANGE_ME@127.0.0.1:5432/loden?schema=public
JWT_SECRET=CHANGE_ME_WITH_A_RANDOM_SECRET_OF_AT_LEAST_32_CHARACTERS
JWT_EXPIRES_IN=7d
CORS_ORIGIN=https://loden-autoecole.fr,https://www.loden-autoecole.fr
API_USE_MEMORY=false

# Notifications email (optionnel). Sans ces variables, les notifications passent en log.
# Provider HTTP Resend (https://resend.com) :
RESEND_API_KEY=
MAIL_FROM="LODEN Auto-École <notifications@loden-autoecole.fr>"
LODEN_NOTIFY_TO=contact@loden-autoecole.fr

# IA (optionnel). Sans GROQ_API_KEY, l'IA est désactivée proprement (message clair).
# Clé gratuite : https://console.groq.com
AI_PROVIDER=groq
AI_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=

# Paiement (optionnel). Sans STRIPE_SECRET_KEY, le paiement tourne en mode mock (aucun débit).
# En production, si STRIPE_SECRET_KEY est défini, STRIPE_WEBHOOK_SECRET est OBLIGATOIRE
# (l'API refuse de démarrer sinon : un paiement ne passe "PAYE" que sur webhook signé).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Seed initial admin, required before first production seed.
LODEN_ADMIN_EMAIL=admin@loden-autoecole.fr
LODEN_ADMIN_PASSWORD=CHANGE_ME_WITH_A_STRONG_TEMPORARY_ADMIN_PASSWORD

# PM2 configure le frontend sur 3000 et l'API sur 4000 via ecosystem.config.cjs.
